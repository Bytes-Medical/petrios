# Petrios — environment variables
# Copy to .env.local and fill in. Server-only values must never be exposed
# to the browser (only NEXT_PUBLIC_* are).

# --- Supabase (required) ---------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only

# --- App URL (required in production) ---------------------------------------
# Used in emailed sign-in links, invite links, and unsubscribe links.
NEXT_PUBLIC_APP_URL=https://your-production-domain.example

# --- Public privacy/compliance disclosure (required in production) -----------
# Rendered on /privacy, /subprocessors, and the DPA framework. These values are
# public; use the controller's legal identity and an actively monitored inbox.
PRIVACY_CONTROLLER_NAME=Your Organisation Legal Name
PRIVACY_CONTROLLER_ADDRESS=Registered address, town, postcode, country
PRIVACY_CONTACT_EMAIL=privacy@your-production-domain.example
# Cover application, database, and backup regions (for example "UK — London").
DATA_HOSTING_REGION=your-deployment-and-backup-regions
# State the actual mechanism after legal review (for example UK adequacy or IDTA).
DATA_TRANSFER_SAFEGUARDS=your-reviewed-transfer-mechanism

# --- Email via Resend (required for real email) ------------------------------
# Leave RESEND_API_KEY unset in development to log emails to the console
# instead of sending (works for any recipient, no provider needed).
RESEND_API_KEY=your-resend-api-key                # server-only
MAIL_FROM=Petrios <no-reply@your-verified-domain>
# MAIL_DEV_REDIRECT=you@example.com               # funnel ALL dev mail to one inbox

# --- Cron jobs (required if you schedule them) --------------------------------
# Shared secret for /api/cron/* routes: Authorization: Bearer CRON_SECRET
CRON_SECRET=generate-a-long-random-string          # server-only

# --- AI (optional — features degrade gracefully without it) -------------------
# Powers feedback summaries and the Petrios Ops agent layer.
OPENAI_API_KEY=your-openai-api-key                 # server-only
# OPENAI_MODEL=gpt-5.5                             # override the default model

# --- Petrios Ops kill switch (optional) -----------------------------------------
# Unset or anything = on; the literal string "false" halts every ops surface.
# OPS_ENABLED=false

# --- Ops chat assistant (optional, default OFF) ----------------------------------
# The organiser chat assistant ships disabled; opt a deployment in explicitly
# after your own safety review. Still subject to OPS_ENABLED.
# OPS_ASSISTANT_ENABLED=true

# --- Petrios Meet video (optional) ------------------------------------------------
# Jitsi domain for built-in video rooms. Default: meet.jit.si (free; the first
# participant may be asked to sign in to Jitsi to open the room). Point at a
# self-hosted Jitsi instance to remove that requirement.
# NEXT_PUBLIC_JITSI_DOMAIN=meet.jit.si

# --- Self-hosted SMTP (takes priority over Resend when SMTP_HOST is set) ------
# SMTP_HOST=mail.your-trust.nhs.uk
# SMTP_PORT=587
# SMTP_USER=petrios
# SMTP_PASS=...
# SMTP_SECURE=false                                # true for implicit TLS (465)

# --- Self-hosted / gateway AI endpoint -----------------------------------------
# OpenAI-compatible base URL (Azure OpenAI, a gateway, or a local model) so AI
# traffic never leaves your network. Default: https://api.openai.com/v1
# OPENAI_BASE_URL=https://your-gateway.internal/v1

# --- Migration runner (self-hosted; scripts/migrate.mjs) -----------------------
# DATABASE_URL=postgres://postgres:password@localhost:5432/postgres

# --- Federation (optional) ------------------------------------------------------
# Ed25519 seed enabling signed teaching-record exports; generate with:
#   node scripts/generate-instance-key.mjs
# INSTANCE_SIGNING_KEY=base64-seed

# --- SEO / Search Console (optional) --------------------------------------------
# Token from Google Search Console's "HTML tag" verification method (the
# content="..." value only). Renders the verification meta tag site-wide.
# GOOGLE_SITE_VERIFICATION=abc123
