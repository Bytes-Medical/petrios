# Byte Teaching — environment variables
# Copy to .env.local and fill in. Server-only values must never be exposed
# to the browser (only NEXT_PUBLIC_* are).

# --- Supabase (required) ---------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only

# --- App URL (required in production) ---------------------------------------
# Used in emailed sign-in links, invite links, and unsubscribe links.
NEXT_PUBLIC_APP_URL=https://your-production-domain.example

# --- Email via Resend (required for real email) ------------------------------
# Leave RESEND_API_KEY unset in development to log emails to the console
# instead of sending (works for any recipient, no provider needed).
RESEND_API_KEY=your-resend-api-key                # server-only
MAIL_FROM=Byte Teaching <no-reply@your-verified-domain>
# MAIL_DEV_REDIRECT=you@example.com               # funnel ALL dev mail to one inbox

# --- Cron jobs (required if you schedule them) --------------------------------
# Shared secret for /api/cron/* routes: ?secret=CRON_SECRET
CRON_SECRET=generate-a-long-random-string          # server-only

# --- AI (optional — features degrade gracefully without it) -------------------
# Powers feedback summaries and the Bytes Ops agent layer.
OPENAI_API_KEY=your-openai-api-key                 # server-only
# OPENAI_MODEL=gpt-5.5                             # override the default model

# --- Bytes Ops kill switch (optional) -----------------------------------------
# Unset or anything = on; the literal string "false" halts every ops surface.
# OPS_ENABLED=false

# --- Byte Meet video (optional) ------------------------------------------------
# Jitsi domain for built-in video rooms. Default: meet.jit.si (free; the first
# participant may be asked to sign in to Jitsi to open the room). Point at a
# self-hosted Jitsi instance to remove that requirement.
# NEXT_PUBLIC_JITSI_DOMAIN=meet.jit.si
